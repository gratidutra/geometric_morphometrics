plotRefToTarget(pca_tt$pc.shapes$PC1min,pca_tt$pc.shapes$PC1max,links=links.trach,method="vector")
plotRefToTarget(pca_tt$pc.shapes$PC1min,pca_tt$pc.shapes$PC1max,links=links.trach,method="points",gridPars=GP1) # alvo = em preto, referÃªncia = em cinza
