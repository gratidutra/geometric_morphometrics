pca_tt <- plotTangentSpace(alg_t_t, label=NULL, verbose =T, groups = tab_to, warpgrids=F) ## Perform PCA of Diachlorus curvipes
pca_tt$pc.summary$importance##saber a parte cumulativa
label_dc <- list(expression('T. occidentalis RS'), expression("T. occidentalis TO"))
a <- cbind(pca_tt$pc.scores, tab_to)
a <- data.frame(a)
a
a$tab_to <- as.factor(a$tab_to)
df_ell <- data.frame()
for(g in levels(a$tab_to)){
df_ell <- rbind(df_ell, cbind(as.data.frame(with(a[a$tab_to==g,], ellipse(cor(PC1, PC2),
scale=c(sd(PC1),sd(PC2)),
centre=c(mean(PC1),mean(PC2))))),tab_to=g))
}
tabanus <- ggplot(data=a, aes(x=PC1, y=PC2,colour=tab_to)) + geom_point(size=2, shape= 18)
tabanus <- tabanus + geom_path(data=df_ell, aes(x=x, y=y,colour=tab_to), size=0.2, linetype=3)
tabanus <- tabanus + scale_color_manual(name ="Populations", labels= label_dc,values=c("#1b9e77", "darkorange4"))
tabanus <- tabanus + scale_shape_manual(name ="Populations", labels= label_dc, values=c(15, 16,17,18))
tabanus <- tabanus + theme(axis.text=element_text(size=12), axis.title=element_text(size=12))
tabanus + theme(legend.text = element_text(size = 12)) + theme(legend.title = element_text(size=12))
# Plotar espécimes contra a média
par(mfrow=c(1,1)) # janela default do gráfico
