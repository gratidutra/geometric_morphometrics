outliers$dist.sort
### Correla횄짠횄짙o do espa횄짠o de forma (shape space) com o espa횄짠o tangente (tangent space)
regdist(alg_tabanus)
ref =mshape(alg_tabanus)
ref
##Definir links entre landmarks
links.trach<-matrix(c(1,2,1,3,1,15,2,4,2,6,4,5,5,6,5,7,6,7,7,8,
8,9,9,10,9,11,11,12,12,13,13,14,14,15),nrow=34,ncol=2,byrow=T)
GP1<-gridPar(pt.bg="yellow",link.col="yellow",link.lty=19)
plotRefToTarget(ref,alg_tabanus[,,88],links=links.trach,method="TPS", gridPars= GP1) ## A deforma횄짠횄짙o na grade 횄짤 a deforma횄짠횄짙o que ele tem em rela횄짠횄짙o a media geral, consegue-se saber onde ele mais difere.
plotRefToTarget(ref,alg_tabanus[,,88],links=links.trach,method="vector", gridPars = GP1)
plotRefToTarget(ref,alg_tabanus[,,88],links=links.trach,method="points",gridPars=GP1) # alvo = em preto, refer횄짧ncia = em cinza
shapiro.test(size)
hist(size)
boxplot(size~tab_esp, ylab = "Centroide Size", xlab = "Species")
anova <-aov(size~tab_esp)
####varia횄짠횄짙o entre popula횄짠횄쨉es
#####
teste = data.frame(size, tab_esp)
p = ggplot(teste,aes(y=size, x= tab_esp, color = tab_esp))+geom_boxplot()
p + scale_color_grey()
boxplot(size~tab_esp, ylab = "Centroide Size", xlab = "Species")
anova <-aov(size~tab_esp)
summary(anova)
TukeyHSD(anova)
pca_tabanus <- plotTangentSpace(alg_tabanus, label=NULL, verbose =T, groups = tab_esp, warpgrids=F)
pca<-pca_tabanus$pc.summary$importance ##saber a parte cumulativa
write.csv(pca, "pca_cumulative.csv")
#write.csv(pca, "pca_cumulative.csv")
summary(tab_esp)
label <- list(expression(italic('T. occidentalis RS')), expression(italic('T. triangulum')),
expression(italic("T. occidentalis TO"))) ## Label to the plot
a <- cbind(pca_tabanus$pc.scores, tab_esp)                                                                      ## Attach the factor for the names to the data
a <- data.frame(a) ## Convert class of 'a' to data frame
a$tab_esp <- as.factor(a$tab_esp)
df_ell <- data.frame()
for(g in levels(a$tab_esp)){
df_ell <- rbind(df_ell, cbind(as.data.frame(with(a[a$tab_esp==g,],
ellipse(cor(PC1, PC2),scale=c(sd(PC1),sd(PC2)),
centre=c(mean(PC1),mean(PC2))))),tab_esp=g))
}
p <- ggplot(data=a, aes(x=PC1, y=PC2,colour=tab_esp, shape=tab_esp)) + geom_point(size=2, shape=18)
p <- p + geom_path(data=df_ell, aes(x=x, y=y,colour=tab_esp), size=0.2, linetype=3)
p <- p + scale_color_manual(name ="Species", labels= label,values=c("#1b9e77", "darkorange4","#7570b3"))
p <- p + theme(axis.text=element_text(size=12), axis.title=element_text(size=12)) +
theme(legend.text = element_text(size = 12)) + theme(legend.title = element_text(size=12))
p
# Plotar esp횄짤cimes contra a m횄짤dia
par(mfrow=c(1,1)) # janela default do gr횄징fico
GP1<-gridPar(pt.bg="gray",link.col="gray",link.lty=1) # cor dos landmarks e links
plotRefToTarget(pca_tabanus$pc.shapes$PC1min,pca_tabanus$pc.shapes$PC1max,links=links.trach,method="TPS")
plotRefToTarget(pca_tabanus$pc.shapes$PC1min,pca_tabanus$pc.shapes$PC1max,links=links.trach,method="vector")
plotRefToTarget(pca_tabanus$pc.shapes$PC1min,pca_tabanus$pc.shapes$PC1max,links=links.trach,method="points",gridPars=GP1) # alvo = em preto, refer횄혘횂짧ncia = em cinza
##bootstrap = 1000
manova<-procD.lm(alg_tabanus~tab_esp, iter=9999, RRPP= TRUE)
manova
resultados<-summary(manova); resultados
##bootstrap = 100
manova.100<-procD.lm(alg_tabanus~tab_esp, iter=99, RRPP= TRUE)
manova.100
summary(manova.100)
###testes a posteriori
par_par= pairwise(manova, groups = tab_esp, covariate = NULL)
par_par
# Pairwise distances between means, summarized two ways
res<-summary(par_par, test.type = "dist", confidence = 0.95, stat.table = TRUE)
res
####CVA forma
cva.1 = CVA(alg_tabanus, tab_esp, weighting = T, tolinv = 1e-10, plot = T, rounds = 1000, cv= T, p.adjust.method = "none")
cva.1
######plot simples
plot(cva.1$CVscores[,1:2], bg = tab_pop, pch =21, typ="p", asp=1)
###plot ggplot
#label_dc <- list(expression('Tabanus occidental'), expression('Regi횄짙o 2'), ('Regi횄짙o 3'))
b <- cbind(cva.1$CVscores, tab_esp)
b <- data.frame(b)
b
b$tab_esp <- as.factor(b$tab_esp)
df_ell <- data.frame()
for(g in levels(b$tab_esp)){
df_ell <- rbind(df_ell, cbind(as.data.frame(with(b[b$tab_esp==g,], ellipse(cor(CV.1, CV.2),
scale=c(sd(CV.1),sd(CV.2)),
centre=c(mean(CV.1),mean(CV.2))))),tab_esp=g))
}
tabanus <- ggplot(data=b, aes(x=CV.1, y=CV.2,colour=tab_esp)) + geom_point(size=2, shape= 18)
tabanus <- tabanus + geom_path(data=df_ell, aes(x=x, y=y,colour=tab_esp), size=0.2, linetype=3)
tabanus <- tabanus + scale_color_manual(name ="Areas", labels= label,values=c("#1b9e77", "darkorange4","#7570b3"))
tabanus <- tabanus + scale_shape_manual(name ="Areas", labels= label, values=c(15, 16,17,18))
tabanus <- tabanus + theme(axis.text=element_text(size=12), axis.title=element_text(size=12))
tabanus + theme(legend.text = element_text(size = 12)) + theme(legend.title = element_text(size=12))
